{
  "name": "ququ",
  "version": "1.2.0",
  "description": "Voice input tool with FunASR integration",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder",
    "asr:serve": "python funasr_server.py"
  },
  "keywords": [
    "voice",
    "input",
    "asr",
    "funasr"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "axios": "^1.5.0"
  },
  "build": {
    "appId": "com.ququ.voice",
    "productName": "Ququ Voice Input",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main-window.js",
      "main-window.html",
      "renderer.js",
      "index.html",
      "indicator-window.html",
      "loading.html",
      "history-window.js",
      "history-window.html",
      "status-window.js",
      "status-window.html",
      "src/**/*",
      "export/logger.js",
      "export/translator.js",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.map",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/docs/**"
    ],
    "asarUnpack": [
      "node_modules/axios/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/app-icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/app-icon.png"
    }
  }
}
